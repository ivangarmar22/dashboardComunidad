{
  "name": "energy-dashboard",
  "version": "1.0.0",
  "description": "Dashboard Comunidad - Endesa",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
